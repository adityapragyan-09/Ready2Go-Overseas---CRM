# ──────────────────────────────────────────────
# Ready2Go CRM — Git Ignore Rules
# ──────────────────────────────────────────────

# ── Environment Files ─────────────────────────
# Ignore ALL .env files (they contain secrets)
.env
.env.*
!.env.example

# ── Node / Frontend ──────────────────────────
node_modules/
.pnpm-store/
jspm_packages/
web_modules/
dist/
dist-ssr/
*.local

# ── Python / Flask ────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Python Virtual Environments ──────────────
.venv/
venv/
ENV/
env/

# ── Upload Folders ────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── Flask Instance Folder ─────────────────────
instance/

# ── System & OS Files ─────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / Editors ─────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*~

# ── Database / Local Data ─────────────────────
*.sqlite
*.db

# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
