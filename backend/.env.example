# ─────────────────────────────────────────────────────────────────────────────
# Ready2Go CRM — Backend Environment Configuration Template
# Copy this file to '.env' in the backend/ directory.
# NEVER commit the actual '.env' file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── 1. Application Settings ──────────────────────────────────────────────────
# Purpose: Core Flask/FastAPI app metadata, reload state, and path routing.
# Required: No (falls back to defaults)
# Examples:
#   ENVIRONMENT=production
#   DEBUG=false
ENVIRONMENT=development
DEBUG=true
APP_NAME="Ready2Go CRM"
APP_VERSION=1.0.0
API_PREFIX=/api/v1
COMPANY_NAME="Ready2Go Overseas"
DATE_FORMAT=%Y-%m-%d
DATETIME_FORMAT="%Y-%m-%d %H:%M:%S"
ENABLE_SOFT_DELETE=true

# ── 2. Security ──────────────────────────────────────────────────────────────
# Purpose: Cryptographic signing keys for sessions and JWT access tokens.
# Required: YES (Do not use defaults in production)
# Examples:
#   SECRET_KEY=4fae859cb82110c73bd95d2c2069b2bb649c0eaef23945de29a3ea77b102919a
#   JWT_SECRET_KEY=e8354c0cfb47120db82b7cf296c0caef93f2f0f8a9bb29c0eaef23945de29a3e
SECRET_KEY=change_me_in_production_secret_key_crm_ready2go
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── 3. Database Connection ───────────────────────────────────────────────────
# Purpose: Connection string for Supabase PostgreSQL database transaction pooling.
# Required: YES
# Examples:
#   DATABASE_URL=postgresql://postgres.xqtmtrgxsljyqbqqnljx:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ── 4. CORS (Cross-Origin Resource Sharing) ──────────────────────────────────
# Purpose: Allowed origin for frontend SPA requests.
# Required: No (falls back to http://localhost:5173)
# Examples:
#   FRONTEND_URL=https://ready2go-crm.vercel.app
FRONTEND_URL=http://localhost:5173

# ── 5. Document Management & Storage ─────────────────────────────────────────
# Purpose: Supabase Storage REST client credentials and uploading filters.
# Required: YES (SUPABASE_URL and SUPABASE_KEY)
# Examples:
#   SUPABASE_URL=https://xqtmtrgxsljyqbqqnljx.supabase.co
#   SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here
SUPABASE_BUCKET=ready2go-documents
MAX_UPLOAD_SIZE_MB=500
UPLOAD_TIMEOUT_SECONDS=600
SIGNED_URL_EXPIRY_MINUTES=60
# Comma-separated list of allowed extensions
ALLOWED_DOCUMENT_TYPES=pdf,jpg,jpeg,png,doc,docx

# ── 6. Pagination & Search Defaults ──────────────────────────────────────────
# Purpose: Default page sizing and query caps to protect DB throughput.
# Required: No (falls back to defaults)
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100
MAX_SEARCH_RESULTS=100
