# ═══════════════════════════════════════════════════════════════
# Ready2Go CRM — Backend Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# Copy this file to '.env' and fill in your values.
# NEVER commit the actual '.env' file to version control.
# NEVER push real secrets to GitHub.
#
# Render Deployment:
#   Set ALL required variables in Render Dashboard → Environment
#
# ═══════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────
# ENVIRONMENT: "development" | "production"
# DEBUG: true | false (enables/disables debug endpoints)
ENVIRONMENT=development
DEBUG=true
APP_NAME="Ready2Go CRM"
APP_VERSION=1.0.0
API_PREFIX=/api/v1

# ── Security (REQUIRED — generate unique random values) ────────
# Generate with: openssl rand -hex 32
# Use DIFFERENT values for SECRET_KEY and JWT_SECRET_KEY
SECRET_KEY=change-this-to-a-random-64-char-hex-string
JWT_SECRET_KEY=change-this-to-a-different-random-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ──────────────────────────────────────────────────
# Production: PostgreSQL via Supabase connection pooling
#   DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# Development: SQLite (local file-based database)
#   DATABASE_URL=sqlite:///./crm.db
DATABASE_URL=sqlite:///./crm.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ── CORS ──────────────────────────────────────────────────────
# Production: Your frontend deployment URL (Vercel/Netlify)
#   FRONTEND_URL=https://your-app.vercel.app
# Development:
FRONTEND_URL=http://localhost:5173

# ── Supabase Storage ──────────────────────────────────────────
# REQUIRED in production. Use Supabase service_role key (NOT anon key).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=ready2go-documents

# ── CRM API Key (Optional) ────────────────────────────────────
# Used by website integration to create leads without JWT.
# Generate a random 64-char hex string.
CRM_API_KEY=

# ── Upload Limits ─────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500
UPLOAD_TIMEOUT_SECONDS=600
SIGNED_URL_EXPIRY_MINUTES=60
ALLOWED_DOCUMENT_TYPES=pdf,jpg,jpeg,png,doc,docx

# ── Pagination & Search ──────────────────────────────────────
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100
MAX_SEARCH_RESULTS=100
