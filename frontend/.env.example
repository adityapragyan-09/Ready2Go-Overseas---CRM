# ─────────────────────────────────────────────────────────────────────────────
# Ready2Go CRM — Frontend Environment Configuration Template
# Copy this file to '.env' in the frontend/ directory.
# NEVER commit the actual '.env' file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── 1. Branding Suffix ───────────────────────────────────────────────────────
# Purpose: Dynamic tab document titles and layout branding banners.
# Default: "Ready2Go CRM"
# Required: No
VITE_APP_NAME="Ready2Go CRM"

# ── 2. API Connection Gateway ────────────────────────────────────────────────
# Purpose: Backend URL endpoint prefix.
# Default: "http://localhost:8000/api/v1"
# Required: YES in production
VITE_API_URL=http://localhost:8000/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── 3. Document Upload Validation Limits ─────────────────────────────────────
# Purpose: Prevents heavy payloads from traveling over connection pipes by rejecting client-side.
# Default: 500 MB
# Required: No
VITE_MAX_UPLOAD_SIZE_MB=500
VITE_ALLOWED_DOCUMENT_TYPES=pdf,jpg,jpeg,png,doc,docx

# ── 4. API Request Timeout ───────────────────────────────────────────────────
# Purpose: Prevents UI hangs. Must be long enough to support 500MB streams.
# Default: 600000 ms (10 minutes)
# Required: No
VITE_API_TIMEOUT_MS=600000

# ── 5. Pagination Defaults ───────────────────────────────────────────────────
# Purpose: Number of applicants rendered per queue card.
# Default: 10
# Required: No
VITE_DEFAULT_PAGE_SIZE=10
