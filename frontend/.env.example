# ═══════════════════════════════════════════════════════════════
# Ready2Go CRM — Frontend Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# Copy this file to '.env' in the frontend/ directory.
# NEVER commit the actual '.env' file to version control.
#
# Vercel/Netlify Deployment:
#   Set these variables in your hosting dashboard → Environment Variables
#
# All variables must be prefixed with VITE_ to be exposed to the client.
# ═══════════════════════════════════════════════════════════════

# ── Application Name ──────────────────────────────────────────
# Used for browser tab titles and branding
# Default: "Ready2Go CRM"
VITE_APP_NAME="Ready2Go CRM"

# ── Backend API URL (REQUIRED in production) ──────────────────
# The full URL to your deployed backend API.
# Examples:
#   VITE_API_BASE_URL=https://ready2go-crm.onrender.com/api/v1
#   VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── Document Upload Limits ────────────────────────────────────
# Max upload size in MB
VITE_MAX_UPLOAD_SIZE_MB=500
# Comma-separated allowed file extensions
VITE_ALLOWED_DOCUMENT_TYPES=pdf,jpg,jpeg,png,doc,docx

# ── API Timeout ───────────────────────────────────────────────
# Milliseconds before a request times out (600000ms = 10 min)
VITE_API_TIMEOUT_MS=600000

# ── Pagination ────────────────────────────────────────────────
# Default items per page for applicant lists
VITE_DEFAULT_PAGE_SIZE=10
