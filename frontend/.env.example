# ═══════════════════════════════════════════════════════════════
# Ready2Go CRM — Frontend Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# Copy this file to '.env' in the frontend/ directory.
# NEVER commit the actual '.env' file to version control.
#
# Netlify Deployment:
#   Set these variables in Netlify Dashboard → Site Settings → Environment Variables
#   Then trigger a new deploy for the changes to take effect.
#
# All variables must be prefixed with VITE_ to be exposed to the client.
# ═══════════════════════════════════════════════════════════════

# ── Application Name ──────────────────────────────────────────
# Used for browser tab titles and branding.
# Optional. Default: "Ready2Go CRM"
VITE_APP_NAME="Ready2Go CRM"

# ── Backend API URL (REQUIRED in production) ──────────────────
# The full URL to your deployed backend API.
# This is REQUIRED for production — without it the app cannot connect.
#
# Production example:
#   VITE_API_BASE_URL=https://ready2go-overseas-crm.onrender.com/api/v1
#
# Development example:
#   VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_BASE_URL=https://ready2go-overseas-crm.onrender.com/api/v1

# ── Document Upload Limits ────────────────────────────────────
# Max upload size in MB (used for client-side validation).
# Optional. Default: 500
VITE_MAX_UPLOAD_SIZE_MB=500
# Comma-separated allowed file extensions.
# Optional. Default: pdf,jpg,jpeg,png,doc,docx
VITE_ALLOWED_DOCUMENT_TYPES=pdf,jpg,jpeg,png,doc,docx

# ── API Timeout ───────────────────────────────────────────────
# Milliseconds before a request times out (600000ms = 10 minutes).
# Optional. Default: 600000
VITE_API_TIMEOUT_MS=600000

# ── Pagination ────────────────────────────────────────────────
# Default items per page for applicant lists.
# Optional. Default: 10
VITE_DEFAULT_PAGE_SIZE=10
